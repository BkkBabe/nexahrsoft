# Database (Supabase session pooler URL)
# Get from: Supabase Dashboard → Project Settings → Database → Session Pooler
DATABASE_URL=postgresql://postgres.xxxxxxxxxxxxxxxxxxxx:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres

# Session secret — use a long random string in production
# Generate one with: openssl rand -base64 32
SESSION_SECRET=change-this-to-a-long-random-secret

# Email (optional) — for sending payslips via email
# Get from: https://resend.com
RESEND_API=re_xxxxxxxxxxxxxxxxxxxx

# Node environment (Railway sets this automatically)
NODE_ENV=production
